---
# Alibaba Cloud Controller Manager — External Platform deployment
# Source: https://github.com/kubernetes/cloud-provider-alibaba-cloud
#
# JINJA TEMPLATE — NOT a directly-apply'able manifest.
# Rendered per-cluster by ansible/playbooks/07-install-cluster.yml using
# cluster_name + base_domain from group_vars/all.yml.
# Render output lands under <output_dir>/rendered/01-alibaba-ccm.yaml.
# See the env: block for KUBERNETES_SERVICE_HOST for the substitution.
#
# Image source: registry-cn-hangzhou.ack.aliyuncs.com/acs/cloud-controller-manager:v2.14.0
#   (per upstream release notes — NOT registry.k8s.io which is empty).
#   IDMS rule in 04-prepare-mirror.yml rewrites to mirror at install time.
#
# 2026-05-30 lessons baked in:
#   - binary path /cloud-controller-manager (not /bin/alibaba-cloud-...)
#   - drop --secure-port, --cloud-provider (not supported by v2.x)
#   - --configure-cloud-routes=false (OVN overlay handles pod net)
#   - cloud config schema is JSON/YAML struct (see ROS template
#     DynamicCustomManifest), not the legacy INI [Global]...
#   - removed trusted-ca volume — was the chicken-and-egg source with
#     CNO inject-trusted-cabundle; CCM uses RHCOS default Mozilla CAs.
#   - removed AccessKey/Secret from Global — RAM role via IMDSv2 (default).
#
# Follows the OpenShift Infrastructure Provider Onboarding Guide
# (Platform External path):
# https://github.com/openshift/infrastructure-provider-onboarding-guide
#
# Companion files:
#   - alibaba-cloud-config.yaml  (ConfigMap `alibaba-cloud-config` in this
#     namespace) — generated by the ROS stack DynamicCustomManifest output
#   - 03-machineconfig-providerid.yaml — sets KUBELET_PROVIDERID for both
#     master and worker nodes (required by the CCM NodeFromProviderID lookup)
#
# Prerequisite: install-config.yaml must contain:
#   platform:
#     external:
#       platformName: alibaba
#       cloudControllerManager: External
#
# Authentication: ECS RAM Role bound to nodes (Instance Principal).
# No AccessKey/SecretKey needed.

# ── Namespace ─────────────────────────────────────────────────────────────────
# Dedicated namespace per the onboarding guide. PSA labels grant the CCM the
# privileged access it needs (hostNetwork, hostPath, etc.) without enabling
# SCC label sync that would later strip them.
apiVersion: v1
kind: Namespace
metadata:
  name: alibaba-cloud-controller-manager
  annotations:
    workload.openshift.io/allowed: management
  labels:
    pod-security.kubernetes.io/enforce: privileged
    pod-security.kubernetes.io/audit: privileged
    pod-security.kubernetes.io/warn: privileged
    pod-security.kubernetes.io/enforce-version: v1.24
    security.openshift.io/scc.podSecurityLabelSync: "false"
    openshift.io/run-level: "0"

---
# (ccm-trusted-ca ConfigMap removed; see Deployment volume comment for why —
#  CNO inject-trusted-cabundle deadlock during install.  CCM uses RHCOS
#  default Mozilla root CA bundle for outbound to *.aliyuncs.com APIs.)

# ── RBAC ──────────────────────────────────────────────────────────────────────
apiVersion: v1
kind: ServiceAccount
metadata:
  name: cloud-controller-manager
  namespace: alibaba-cloud-controller-manager

---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: system:cloud-controller-manager
  labels:
    kubernetes.io/cluster-service: "true"
rules:
  - apiGroups: [""]
    resources: [events]
    verbs: [create, patch, update]
  - apiGroups: [""]
    resources: [nodes]
    verbs: [get, list, watch, delete, patch, update]
  - apiGroups: [""]
    resources: [nodes/status]
    verbs: [patch]
  - apiGroups: [""]
    resources: [services]
    verbs: [get, list, watch, patch, update]
  - apiGroups: [""]
    resources: [services/status]
    verbs: [patch, update]
  - apiGroups: [""]
    resources: [serviceaccounts]
    verbs: [create, get]
  - apiGroups: [""]
    resources: [persistentvolumes]
    verbs: [get, list, watch, update]
  - apiGroups: [""]
    resources: [endpoints]
    verbs: [create, get, list, watch, update]
  - apiGroups: [""]
    resources: [configmaps]
    verbs: [get, list, watch]
  - apiGroups: [""]
    resources: [secrets]
    verbs: [get, list, watch]
  - apiGroups: [coordination.k8s.io]
    resources: [leases]
    verbs: [get, list, watch, create, update]
  # CCM v2.x watches EndpointSlice (replaces v1 Endpoints for LB backend
  # tracking, modern k8s preferred API).  Without this, CCM logs
  #   "endpointslices.discovery.k8s.io is forbidden: User
  #    system:serviceaccount:alibaba-cloud-controller-manager:
  #    cloud-controller-manager cannot list resource endpointslices ..."
  # and reflector tight-loops every ~5 s.  Observed 2026-05-30.
  - apiGroups: [discovery.k8s.io]
    resources: [endpointslices]
    verbs: [get, list, watch]

---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: alibaba-cloud-controller-manager
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: system:cloud-controller-manager
subjects:
  - kind: ServiceAccount
    name: cloud-controller-manager
    namespace: alibaba-cloud-controller-manager

---
# ── Deployment ────────────────────────────────────────────────────────────────
# Labels per the onboarding guide:
#   k8s-app                                          — identifies the workload
#   infrastructure.openshift.io/cloud-controller-manager — identifies the
#     external CCM provider; consumed by OpenShift dashboards / tooling
apiVersion: apps/v1
kind: Deployment
metadata:
  name: alibaba-cloud-controller-manager
  namespace: alibaba-cloud-controller-manager
  labels:
    k8s-app: alibaba-cloud-controller-manager
    infrastructure.openshift.io/cloud-controller-manager: AlibabaCloud
spec:
  replicas: 2
  strategy:
    type: Recreate
  selector:
    matchLabels:
      k8s-app: alibaba-cloud-controller-manager
      infrastructure.openshift.io/cloud-controller-manager: AlibabaCloud
  template:
    metadata:
      annotations:
        # Mark the workload as management-tier so the workload partitioning
        # admission controller can pin it to reserved control-plane CPUs when
        # workload partitioning is enabled (single-node / telco profiles).
        target.workload.openshift.io/management: '{"effect": "PreferredDuringScheduling"}'
      labels:
        k8s-app: alibaba-cloud-controller-manager
        infrastructure.openshift.io/cloud-controller-manager: AlibabaCloud
    spec:
      hostNetwork: true
      serviceAccountName: cloud-controller-manager
      priorityClassName: system-cluster-critical
      nodeSelector:
        node-role.kubernetes.io/master: ""
      tolerations:
        # Per the onboarding guide — required for first-boot / uninitialised
        # node scheduling so the CCM can run before nodes are fully ready.
        - key: CriticalAddonsOnly
          operator: Exists
        - key: node-role.kubernetes.io/master
          operator: Exists
          effect: NoSchedule
        - key: node.cloudprovider.kubernetes.io/uninitialized
          operator: Exists
          effect: NoSchedule
        - key: node.kubernetes.io/not-ready
          operator: Exists
          effect: NoSchedule
        - key: node.kubernetes.io/unreachable
          operator: Exists
          effect: NoExecute
          tolerationSeconds: 120
      affinity:
        podAntiAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            - topologyKey: kubernetes.io/hostname
              labelSelector:
                matchLabels:
                  k8s-app: alibaba-cloud-controller-manager
                  infrastructure.openshift.io/cloud-controller-manager: AlibabaCloud
      containers:
        - name: cloud-controller-manager
          # Official upstream image (per release notes:
          # https://github.com/kubernetes/cloud-provider-alibaba-cloud/releases/tag/v2.14.0).
          # registry-cn-hangzhou.ack.aliyuncs.com is upstream's canonical
          # publishing endpoint, NOT registry.k8s.io (the registry.k8s.io
          # /provider-alibaba-cloud repo slot exists but has no manifests
          # published — verified 2026-05-30).
          #
          # IDMS rule in 04-prepare-mirror.yml rewrites this path to the
          # mirror at install time, so masters pull from
          # mirror:8443/acs/cloud-controller-manager without crossing the
          # border to Hangzhou.
          image: registry-cn-hangzhou.ack.aliyuncs.com/acs/cloud-controller-manager:v2.14.0
          imagePullPolicy: IfNotPresent
          # v2.x of the Alibaba CCM has its own minimal flag set — quite
          # different from the generic kube-controller-manager / out-of-tree
          # provider template most cloud CCMs derive from.  Notably:
          #   - binary path is /cloud-controller-manager (NOT
          #     /bin/alibaba-cloud-controller-manager as older docs say),
          #   - no --secure-port / no --cloud-provider (alibabacloud is
          #     the only target this binary knows),
          #   - --configure-cloud-routes defaults to true and requires
          #     --cluster-cidr; OVN overlay handles pod networking so
          #     route reconciliation by the cloud provider is unnecessary
          #     → set to false,
          #   - --health-probe-bind-addr replaces --secure-port for the
          #     liveness/readiness HTTP endpoint (default :10258).
          # Auth: --enable-imdsv2=true (default) → reads RAM-role creds
          # from ECS metadata service, no AccessKey/Secret needed.
          command:
            - /cloud-controller-manager
            - --cloud-config=/etc/kubernetes/cloud-config/cloud.conf
            - --configure-cloud-routes=false
            - --leader-elect=true
            - --leader-elect-resource-namespace=alibaba-cloud-controller-manager
            - --health-probe-bind-addr=:10258
            - -v=2
          # Override InClusterConfig kube-apiserver target.  By default Go's
          # client-go reads KUBERNETES_SERVICE_HOST/PORT from env (set by
          # kubelet to "kubernetes.default.svc" → ClusterIP 172.30.0.1).
          # ClusterIP NAT requires kube-proxy or OVN-kubernetes-node, but
          # CCM is in the BOOT chain *before* OVN can deploy — CNO needs
          # nodes Ready, which needs CCM to remove cloudprovider.uninitialized
          # taint, which needs CCM to be running.  Observed 2026-05-30:
          # CCM stuck at `dial tcp 172.30.0.1:443: i/o timeout` (no NAT
          # available pre-OVN) → leader election never completes → taint
          # never removed → cluster install deadlocks.
          #
          # Workaround: point CCM directly at api-int.<cluster>.<base> via
          # NLB.  hostNetwork pod, uses host DNS resolver which picks up
          # the PrivateZone record, NLB hairpins to bootstrap kube-apiserver.
          # Bypasses ClusterIP entirely.
          #
          # Templated per-cluster by ansible/playbooks/07-install-cluster.yml
          # (renders this .j2 to <output_dir>/rendered/01-alibaba-ccm.yaml
          # before slurp+upload).  Do NOT `oc apply -f` the .j2 directly —
          # render with `ansible.builtin.template` or
          # `jinja2 -D cluster_name=... base_domain=...` first.
          env:
            - name: KUBERNETES_SERVICE_HOST
              value: api-int.{{ cluster_name }}.{{ base_domain }}
            - name: KUBERNETES_SERVICE_PORT
              value: "6443"
          ports:
            - name: health
              containerPort: 10258
              protocol: TCP
          resources:
            requests:
              cpu: 200m
              memory: 50Mi
          terminationMessagePolicy: FallbackToLogsOnError
          volumeMounts:
            - name: host-etc-kube
              mountPath: /etc/kubernetes
              readOnly: true
            - name: cloud-config
              mountPath: /etc/kubernetes/cloud-config
              readOnly: true
            # trusted-ca volume removed: v2.x CCM talks to Alibaba public
            # APIs (https://*.aliyuncs.com), which the RHCOS base Mozilla
            # root CA bundle (/etc/pki/ca-trust/extracted/) covers natively
            # — no need for CNO's inject-trusted-cabundle plumbing, which
            # caused a chicken-and-egg deadlock during install (CNO can't
            # schedule until CCM removes the taint; CCM can't start until
            # CNO injects ca-bundle.crt).
      volumes:
        - name: host-etc-kube
          hostPath:
            path: /etc/kubernetes
            type: Directory
        - name: cloud-config
          configMap:
            name: alibaba-cloud-config
