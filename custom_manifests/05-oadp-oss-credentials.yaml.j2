---
# OSS credentials for OADP/Velero backup storage. ANSIBLE TEMPLATE — rendered by
# 08-deploy-post-install.yml from the oadp_oss_access_key_id / _secret vars and
# applied via stdin (never written to disk on the jump host).
#
# The AK/SK MUST be a dedicated RAM user with MINIMUM PRIVILEGE on the backup
# bucket only — do NOT reuse the node instance RAM Role credentials:
#   oss:PutObject, oss:GetObject, oss:DeleteObject, oss:ListObjects,
#   oss:ListBuckets, oss:GetBucketLocation, oss:PutBucketLifecycle,
#   oss:GetBucketLifecycle
#
# RAM policy template (attach to the backup RAM user, scope to oadp_oss_bucket):
#   {
#     "Version": "1",
#     "Statement": [{
#       "Effect": "Allow",
#       "Action": [
#         "oss:PutObject", "oss:GetObject", "oss:DeleteObject",
#         "oss:ListObjects", "oss:ListBuckets", "oss:GetBucketLocation",
#         "oss:PutBucketLifecycle", "oss:GetBucketLifecycle"
#       ],
#       "Resource": [
#         "acs:oss:*:*:{{ oadp_oss_bucket }}",
#         "acs:oss:*:*:{{ oadp_oss_bucket }}/*"
#       ]
#     }]
#   }
apiVersion: v1
kind: Secret
metadata:
  name: cloud-credentials
  namespace: openshift-adp
type: Opaque
stringData:
  # Velero expects AWS-compatible credential format for S3-compatible storage.
  cloud: |
    [default]
    aws_access_key_id={{ oadp_oss_access_key_id }}
    aws_secret_access_key={{ oadp_oss_access_key_secret }}
