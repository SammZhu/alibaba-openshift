#jinja2: trim_blocks: True, lstrip_blocks: True
# agent-config.yaml for the Agent-based Installer (installation_method=Agent-based).
# Rendered by ansible/tasks/iso_agent.yml.
#
# Network model (ENI-first, 2026-06-16): hosts[] binds each master's pre-created
# ENI MAC -> hostname.  This is the ONLY way the rendezvous/node-zero gets a
# deterministic name: the assisted agent reads the hostname from config at
# registration, so it no longer matters whether the OS hostname has settled from
# DHCP/PTR yet (an earlier DHCP-only + empty-hosts[] attempt left node-zero named
# after its MAC, because it gathered inventory while its hostname was still
# localhost).  The MACs are known before the ISO is built because 06 phase-1
# boots the masters from a placeholder image (fixed IPs, auto primary ENIs) and
# harvests those ENIs' MACs; 06b phase-2 reimages the masters to the agent image
# in place (ReplaceSystemDisk keeps the ENI/MAC/IP).  We still rely on DHCP to
# hand each ENI its fixed IP (no static NMState / networkConfig), so a host entry
# is just {hostname, role, MAC matcher, rootDeviceHints=/dev/vda}.  rendezvousIP
# must equal master-1's fixed IP (ROS RendezvousIp / ansible rendezvous_ip, in
# the masters' subnet, e.g. 10.0.32.0/20).
# bootArtifactsBaseURL — air-gap: the External-platform agent ISO is always a
# MINIMAL ISO that fetches its ~1 GB rootfs over HTTP at boot. Without this it
# points at the public rhcos.mirror.openshift.com (breaks air-gap, slow/blocked
# in China). Point it at an in-VPC HTTP server on the mirror ECS (tasks/
# iso_agent.yml serves boot-artifacts/agent.x86_64-rootfs.img there via a
# systemd python http.server on :8080; the mirror SG opens 8080 to the VPC).
# Nodes then pull the rootfs from the mirror ECS in-VPC, no public internet.
apiVersion: v1alpha1
kind: AgentConfig
metadata:
  name: {{ cluster_name }}
rendezvousIP: {{ rendezvous_ip }}
bootArtifactsBaseURL: http://{{ mirror_private_ip }}:8080
{% if (master_mac1 | default('')) | length > 0 %}
hosts:
  - hostname: {{ cluster_name }}-master-1
    role: master
    rootDeviceHints:
      deviceName: /dev/vda
    interfaces:
      - name: eth0
        macAddress: "{{ master_mac1 | lower }}"
  - hostname: {{ cluster_name }}-master-2
    role: master
    rootDeviceHints:
      deviceName: /dev/vda
    interfaces:
      - name: eth0
        macAddress: "{{ master_mac2 | lower }}"
  - hostname: {{ cluster_name }}-master-3
    role: master
    rootDeviceHints:
      deviceName: /dev/vda
    interfaces:
      - name: eth0
        macAddress: "{{ master_mac3 | lower }}"
{% else %}
# Fallback (no MACs harvested — e.g. ENI-first phase-1 not run): empty hosts[],
# nodes get DHCP-pinned IPs but the rendezvous may fall back to a MAC hostname.
hosts: []
{% endif %}
