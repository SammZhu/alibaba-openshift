---
# Copy to group_vars/all.yml and edit. group_vars/all.yml is gitignored.

# ── Cluster identity ─────────────────────────────────────────────────────────
cluster_name:        cluster1
base_domain:         example.local
# ⚠️ Pin to a specific patch (X.Y.Z), NOT channel form (X.Y).
# Single source of truth — Phase 01 creates AI cluster with this,
# Phase 04 PATCHes AI to enforce this, build-mirror-tarball.sh's
# OPENSHIFT_VERSION should match this (set OPENSHIFT_VERSION=X.Y.Z
# in env before running the script).
#
# Channel form ("4.20") makes AI auto-resolve to latest patch via
# Cincinnati at cluster-create time — but your mirror tarball was
# built for a specific patch.  Any drift = master ECS hits "Failed
# to fetch container images" and AI silently reverts cluster from
# preparing-for-installation back to ready without retrying.
#
# 04 has a hard assert that fails fast if this is channel form.
openshift_version:   "4.20.22"

# ── Alibaba Cloud ────────────────────────────────────────────────────────────
region:              cn-wulanchabu
zone:                cn-wulanchabu-a
zone2:               cn-wulanchabu-b
zone3:               cn-wulanchabu-c   # Agent-based multi-AZ control plane (master-3); leave for AI/single-AZ
oss_bucket:          openshift-iso-samzhu-test   # must be globally unique
aliyun_profile:      openshift-test              # aliyun-cli profile

# ── OADP / OSS backup (optional, day-2) ──────────────────────────────────────
# Backs up cluster resources + PV data to Alibaba Cloud OSS (S3-compatible) via
# the OADP/Velero operator. Disabled by default. To enable: provision an OSS
# bucket + a DEDICATED minimum-privilege RAM user (oss:* on that bucket only —
# do NOT reuse the node instance RAM role), then set oadp_enabled: true and fill
# the AK/SK below in group_vars/all.yml (gitignored) or ansible-vault — NEVER
# commit real credentials. Air-gap: rebuild the mirror tarball with OADP_MIRROR=true
# so the redhat-oadp-operator package is mirrored into the private registry.
oadp_enabled:               false
oadp_channel:               stable-1.4
# Backup bucket is SEPARATE from the install ISO bucket (oss_bucket above).
oadp_oss_bucket:            "openshift-backup-{{ cluster_name }}"
oadp_region:                "{{ region }}"
# Internal OSS endpoint (no egress charge) when cluster + bucket share a region.
# Set false only for cross-region DR.
oadp_oss_internal_endpoint: true
oadp_backup_prefix:         velero
# Dedicated backup RAM user AK/SK. Leave blank to deploy the OADP operator only
# (subscription) and skip the credentials Secret + DataProtectionApplication.
oadp_oss_access_key_id:     ""
oadp_oss_access_key_secret: ""

# ── Cluster topology ─────────────────────────────────────────────────────────
# cluster_topology controls which ROS template + AI installer mode is used:
#   ha  (default) — 3-master HA cluster (ros-templates/cluster-stack.yaml,
#                   Assisted Installer high_availability_mode=Full)
#   sno           — Single Node OpenShift (ros-templates/cluster-stack-sno.yaml,
#                   high_availability_mode=None).  ~33% of HA cost.  Use for
#                   dev / smoke / iteration.  See docs/SNO-MODE.md.
cluster_topology:     ha

# ── Compute sizing ───────────────────────────────────────────────────────────
# For cluster_topology=sno the ROS layer pins control_plane_count=1 +
# compute_count=0 via AllowedValues — values below are silently overridden.
control_plane_count:  3
control_plane_type:   ecs.g7.xlarge
compute_count:        0       # 0 = compact (masters schedule workloads)
compute_type:         ecs.g7.xlarge
system_disk_category: cloud_essd
system_disk_size:     120
# Size (GB) of the /dev/vdb install target.  Must be >= 100 — OpenShift
# rejects smaller install disks ("Disk is too small … 100 GB required").
# RHCOS uses ~5 GB; the rest is unused but provides headroom and is
# never copied by the vdb→vda clone hook (sector-bounded dd).
install_disk_size:    100

# ── Network ──────────────────────────────────────────────────────────────────
vpc_cidr:             10.0.0.0/16
private_subnet_cidr:  10.0.16.0/20
private_subnet_cidr2: 10.0.32.0/20
private_subnet_cidr3: 10.0.48.0/20   # Agent-based multi-AZ master-3 (zone3)
public_subnet_cidr:   10.0.0.0/20
rendezvous_ip:        10.0.16.5      # ABI master-1 (zone1) fixed IP; master-2=10.0.32.6 (z2), master-3=10.0.48.7 (z3)
ingress_vip:          10.0.16.6

# ── Jump host (SSH into VPC) ─────────────────────────────────────────────────
enable_jump_host:     false
jump_host_type:       ecs.t6-c1m1.large

# ── Files (resolved at runtime) ──────────────────────────────────────────────
pull_secret_file:     "{{ lookup('env', 'HOME') }}/.openshift/pull-secret.json"
ssh_pub_key_file:     "{{ lookup('env', 'HOME') }}/.ssh/openshift_ed25519.pub"
ssh_priv_key_file:    "{{ lookup('env', 'HOME') }}/.ssh/openshift_ed25519"
offline_token_file:   "{{ lookup('env', 'HOME') }}/.openshift/offline-token"

# ── Output directory (kubeconfig, ISO, etc.) ─────────────────────────────────
output_dir:           "{{ lookup('env', 'HOME') }}/openshift-install/{{ cluster_name }}"

# ── Installation method ──────────────────────────────────────────────────────
# Assisted    → run via site.yml       (assisted-service REST API; tested path)
# Agent-based → run via site-agent.yml (ABI; fully air-gapped, no assisted-service).
#               ABI is multi-AZ: master-1/2/3 spread across zone/zone2/zone3
#               (PrivateSubnetCidr/2/3), each pinned to a fixed IP that cloud DHCP
#               delivers; agent-config hosts[] binds each master's MAC→hostname.
#               rendezvous_ip = master-1's IP in zone1 (10.0.16.5 default — matches
#               the multi-AZ layout; no longer the old all-zone2 10.0.32.5).
#               Value is matched case-insensitively.
installation_method:  Assisted

# ── Repo locations on the local machine ──────────────────────────────────────
repo_root:            "{{ playbook_dir }}/../.."

# ── Teardown defaults ────────────────────────────────────────────────────────
# These become the defaults for 99-teardown.yml so you don't need -e flags.
# Override on the command line: -e teardown_from=1 -e teardown_confirmed=true
#
# teardown_from:
#   1 → AI cluster + infra-env records only (no Aliyun cost; fast)
#   2 → + ECS custom image
#   3 → + ROS stack (VPC / ECS / SLB / NAT / EIP / jump host)   ← typical rebuild
#   4 → + app-layer cleanup (LoadBalancer SVCs + PVCs) first     ← full installed cluster
teardown_from:      3        # default scope when you run 99-teardown.yml
keep_image:         true     # true = preserve ECS image on stack rebuild (saves ~30 min re-upload)
teardown_confirmed: false    # true = skip "Type yes to proceed" prompt (set true for CI/CD)

# ── Disconnected / mirror registry ───────────────────────────────────────────
# When mirror_enabled=true, Phase 03 creates a dedicated mirror ECS inside
# the cluster VPC at a static private IP.  Cluster nodes pull all images
# from this mirror instead of quay.io (solves cross-border connectivity
# issues in China regions).
#
# Generate the tarball ONCE on a host with good quay.io connectivity:
#   scripts/build-mirror-tarball.sh
#
# Then enable here and run Phase 01 → 02 → 03 → 04 as normal.
mirror_enabled:         false
mirror_oss_object:      "mirror-tarballs/{{ cluster_name }}-{{ openshift_version }}.tar"
mirror_private_ip:      "10.0.16.4"           # static IP in private_subnet_cidr
# Mirror ECS sizing — 03 picks per mirror_flow (P3-COST.5):
#   fresh path (no snapshot in state → oc-mirror v2 d2m runs):
#                                    needs ≥16 GB; ecs.g7.xlarge default
#   restore path (snapshot present → d2m skipped):
#                                    peak ~2 GB; ecs.g7.large enough
#                                    (~¥0.27/h cheaper than xlarge)
#
# Backwards compat: set `mirror_instance_type` non-empty to override both —
# 03 will use that literal value regardless of mirror_flow.
#
# See docs/MIRROR.md "Sizing per mirror flow" for the OOM threshold detail.
mirror_instance_type_fresh:   "ecs.g7.xlarge"
mirror_instance_type_restore: "ecs.g7.large"
mirror_instance_type:         ""              # legacy explicit override; empty = use per-flow
# 100 GB peak runtime usage; 200 GB leaves room for re-runs.
mirror_data_disk_size:  200
mirror_init_user:       "mirror-admin"
mirror_init_password:   ""                    # leave empty to auto-generate

# ── Worker pool sizing (Phase 12 multi-AZ MachineDeployments) ────────────
# Cluster worker count = worker_zone_count * replicas_per_zone (one
# MachineDeployment per AZ). Phase 12 is declarative: lowering these scales the
# cluster DOWN on the next site-post run (reclaiming the ECS) — the same knob that
# scaled it up. Defaults keep a lean master + 2-worker / 2-AZ footprint, enough for
# CSI (cross-node RWX) + cross-AZ. Set worker_zone_count: 3 for full 3-AZ spread.
worker_zone_count:   2
replicas_per_zone:   1
# Drop known-bad AZs from worker placement (e.g. an AZ where the CSI disk-node gets
# stuck on a per-AZ credential quirk). The zone IDs here are removed from the
# candidate set before worker_zone_count picks. Leave empty unless you hit one.
worker_exclude_zones: []         # e.g. ["cn-wulanchabu-c"]

# ── State.yml fields written by ansible (DO NOT set manually) ────────────
# Both architectures populate distinct fields so they do not collide:
#
# Flow A (monolithic, legacy):
#   ros_stack_id           single stack created by 03-create-stack.yml
#
# Flow B (split, mirror/cluster decoupled):
#   mirror_stack_id        persistent stack from 02b-create-mirror-stack.yml
#   cluster_stack_id       short-lived stack from 03-create-cluster-stack.yml
#   mirror_vpc_id, mirror_private_vsw_1/2, mirror_node_ram_role, ...
#                          mirror-stack outputs consumed by cluster-stack
#
# Pick a flow per README "Two flows".  Do not mix.

# ── Internal: endpoints (don't change unless instructed) ─────────────────────
assisted_api:  https://api.openshift.com/api/assisted-install/v2
sso_url:       https://sso.redhat.com/auth/realms/redhat-external/protocol/openid-connect/token
